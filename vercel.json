{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "N8N_WEBHOOK_URL": "@n8n-webhook-url",
    "WEBHOOK_SECRET":  "@webhook-secret"
  }
}
